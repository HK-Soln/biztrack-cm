# Admin API specific
NODE_ENV=development
ADMIN_PORT=3002

# Admin auth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_ACCESS_SECRET=
ADMIN_JWT_REFRESH_SECRET=
ADMIN_ACCESS_TOKEN_TTL=1h
ADMIN_REFRESH_TOKEN_TTL_HOURS=8

# Password hashing
PASSWORD_SALT_ROUNDS=12

# IP restriction (comma-separated). Empty = open (dev); set office/VPN IPs in prod.
ADMIN_ALLOWED_IPS=

# CORS (comma-separated). Empty = allow all (dev); set admin-web origin in prod.
ADMIN_CORS_ORIGINS=

# First super admin (used by the seed script — change password after first login)
ADMIN_SEED_EMAIL=admin@biztrack.cm
ADMIN_SEED_PASSWORD=

# Shared with apps/api
DATABASE_URL=
REDIS_URL=
