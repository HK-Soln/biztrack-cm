# desktop-v2 build configuration. Copy to `.env` (or `.env.local`) for local dev, and set the
# same keys in Vercel (cloud/web build) and the GitHub Environment (desktop release).
#
# BOTH keys below are REQUIRED — there is no localhost fallback. A build/deploy that omits them
# fails loudly (web build errors; desktop app won't start). See src/shared/config.ts.

# API base URL, including the /api/v1 prefix.
VITE_API_URL=http://localhost:3001/api/v1

# Root domain for customer storefronts (`<slug>.<root>`).
VITE_STOREFRONT_DOMAIN=localhost:3010

# --- optional, dev/testing only (main process) ---
# DESKTOP_DB_PATH=
# ELECTRON_RENDERER_URL=
