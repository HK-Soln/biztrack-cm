{
  "name": "@biztrack/desktop-v2",
  "version": "0.0.1",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "tsc -p ../../packages/electron-core/tsconfig.json && electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "seed:dev": "node scripts/seed-dev-db.js",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "postinstall": "node scripts/rebuild-sqlite.js"
  },
  "dependencies": {
    "@biztrack/electron-core": "workspace:*",
    "@biztrack/http-client": "workspace:*",
    "@biztrack/templates": "workspace:*",
    "@biztrack/types": "workspace:*",
    "@biztrack/ui": "workspace:*",
    "@biztrack/utils": "workspace:*",
    "@tanstack/react-query": "^5.62.7",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "pdf-to-printer": "^5.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@biztrack/typescript-config": "workspace:*",
    "@electron/rebuild": "3.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
