{
  "name": "@biztrack/desktop-v2",
  "version": "0.0.1",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "node scripts/dev-full.js",
    "dev:next": "next dev -p 3020",
    "build:next": "next build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "node scripts/generate-build-config.js && next build && tsc -p tsconfig.electron.json",
    "start": "node scripts/start-prod.js",
    "seed:dev": "node scripts/seed-dev-db.js",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "type-check:electron": "tsc -p tsconfig.electron.json --noEmit",
    "postinstall": "node scripts/rebuild-sqlite.js"
  },
  "dependencies": {
    "@biztrack/electron-core": "workspace:*",
    "@biztrack/http-client": "workspace:*",
    "@biztrack/types": "workspace:*",
    "@biztrack/utils": "workspace:*",
    "@tanstack/react-query": "^5.62.7",
    "better-sqlite3": "^11.7.0",
    "next": "^15.1.3",
    "next-themes": "^0.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@biztrack/eslint-config": "workspace:*",
    "@biztrack/typescript-config": "workspace:*",
    "@electron/rebuild": "3.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-updater": "^6.3.9",
    "eslint": "^9.32.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  }
}
