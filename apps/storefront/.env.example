# Storefront configuration. Copy to `.env.local` for local dev.
#
# BOTH keys are REQUIRED — there is no localhost fallback. A build/deploy that omits them fails
# loudly rather than shipping a store pointed at localhost. See src/lib/config.ts.

# API base URL, including the /api/v1 prefix.
# BUILD-TIME: Next inlines NEXT_PUBLIC_* into the client bundle, so this must be set wherever
# `next build` runs — for CI that is the GitHub Environment, not just the Vercel project.
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Root domain(s) for customer storefronts (`<slug>.<root>`). Comma-separated to serve several.
# Must match the desktop/cloud app's VITE_STOREFRONT_DOMAIN.
# RUNTIME: server-only, read per request — set this in the Vercel project env as well.
STORE_ROOT_DOMAIN=localhost
